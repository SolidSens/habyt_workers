# Gmail API Settings
# Path to your credentials.json file downloaded from Google Cloud Console
GMAIL_CREDENTIALS_PATH=credentials.json
# The token.json file will be created automatically after the first login
GMAIL_TOKEN_PATH=token.json

# WalletThat Selenium Settings
# Path to your Chrome User Data directory
# macOS Example: /Users/<your-user>/Library/Application Support/Google/Chrome
# Windows Example: C:\Users\<your-user>\AppData\Local\Google\Chrome\User Data
CHROME_USER_DATA_DIR="/Users/brunopinillarojas/Library/Application Support/Google/Chrome"
# The specific profile name to use (e.g., Profile 1, Default)
CHROME_PROFILE_NAME=Default
# Path to Chrome executable
# macOS Example: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROME_BINARY_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"

# Logging
CHROME_DEBUG_PORT=
LOG_LEVEL=INFO
